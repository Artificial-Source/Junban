# =============================================================================
# ASF Junban — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional unless marked (REQUIRED).

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Storage profile. Repo-run dev commands set this to "dev" automatically so
# their data stays separate from packaged desktop installs.
# JUNBAN_PROFILE=daily

# Where to store the SQLite database file.
# Leave unset to use the active profile default:
# - daily -> ./data/junban.db
# - dev   -> ./data/dev/junban.db
# DB_PATH=./data/junban.db

# Storage mode: "sqlite" for database, "markdown" for flat files (default: sqlite)
STORAGE_MODE=sqlite

# Path for Markdown task files when using STORAGE_MODE=markdown.
# Leave unset to use the active profile default:
# - daily -> ./tasks/
# - dev   -> ./tasks/dev/
# MARKDOWN_PATH=./tasks/

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Port for the dev server (default: 5173)
PORT=5173

# Default theme: light, dark (default: light)
DEFAULT_THEME=light

# Locale for natural language parsing (default: en)
NLP_LOCALE=en

# -----------------------------------------------------------------------------
# Plugin System
# -----------------------------------------------------------------------------

# Directory for community plugins (default: ./plugins/)
PLUGIN_DIR=./plugins/

# Enable plugin sandboxing (default: true)
PLUGIN_SANDBOX=true

# Plugin registry URL for fetching community plugins (default: built-in sources.json)
# PLUGIN_REGISTRY_URL=https://raw.githubusercontent.com/Artificial-Source-Foundation/junban-plugins/main/registry.json

# Maximum plugin size in MB (default: 10)
PLUGIN_MAX_SIZE_MB=10

# -----------------------------------------------------------------------------
# CLI
# -----------------------------------------------------------------------------

# Default output format for CLI: text, json (default: text)
CLI_OUTPUT_FORMAT=text

# Path to task data when using CLI standalone (default: uses DB_PATH)
# CLI_DATA_PATH=./data/junban.db

# -----------------------------------------------------------------------------
# Sync (future — not yet implemented)
# -----------------------------------------------------------------------------

# Enable sync (default: false)
# SYNC_ENABLED=false

# Sync provider: caldav, git, webdav (default: none)
# SYNC_PROVIDER=

# CalDAV server URL
# CALDAV_URL=

# CalDAV credentials
# CALDAV_USERNAME=
# CALDAV_PASSWORD=
