{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Junban",
  "version": "1.0.8",
  "identifier": "com.asf.junban",
  "build": {
    "beforeDevCommand": "pnpm tauri:prepare-sidecar && pnpm dev:full",
    "beforeBuildCommand": "pnpm build && pnpm tauri:prepare-sidecar && pnpm tauri:validate-sidecar",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Junban",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "quick-capture",
        "title": "Quick Capture",
        "url": "/quick-capture",
        "width": 680,
        "height": 72,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:* http://localhost:* https:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": ["../dist/**/*", "./gen/sidecar/"],
    "externalBin": ["binaries/junban-node"],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Artificial-Source/Junban/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCQ0JGQzQ1QkU5OEU3RkUKUldUKzU1aStSZnpMU3poV2pvL2NHOVBXdjBqYUJkODdUTk9NT3lHeFl6Y3hObndmY0czMHBJcTcK"
    }
  }
}
