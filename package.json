{
  "name": "asf-saydo",
  "version": "1.0.0",
  "description": "ASF Saydo — Open-source task management with an Obsidian-style plugin system",
  "author": "AI Strategic Forum (ASF)",
  "repository": {
    "type": "git",
    "url": "https://github.com/asf-org/saydo.git"
  },
  "homepage": "https://github.com/asf-org/saydo",
  "bugs": {
    "url": "https://github.com/asf-org/saydo/issues"
  },
  "keywords": [
    "task-manager",
    "todo",
    "ai",
    "plugins",
    "local-first",
    "sqlite",
    "tauri",
    "voice",
    "mcp"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "vite preview",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' '*.{ts,js,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' '*.{ts,js,json}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "cli": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "test:e2e": "npx playwright test",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "release:prepare": "tsx scripts/prepare-release.ts",
    "release:tag": "git tag -a v$(node -p \"require('./package.json').version\") -m \"v$(node -p \"require('./package.json').version\")\" && git push --tags"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/transformers": "^3.8.1",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "better-sqlite3": "^11.7.0",
    "chrono-node": "^2.7.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.1",
    "emoji-picker-react": "^4.18.0",
    "framer-motion": "^12.35.2",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.564.0",
    "onnxruntime-web": "^1.24.1",
    "openai": "^6.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.0",
    "tar": "^7.5.7",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/tar": "^6.1.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.55.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.29.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
